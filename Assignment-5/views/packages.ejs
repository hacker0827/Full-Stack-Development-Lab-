<%- include('partials/head') %>
<%- include('partials/header') %>

<main class="container section-space">
  <section class="section-title-wrap listing-header">
    <div>
      <p class="eyebrow">Plan by budget and destination</p>
      <h1>Travel Packages</h1>
    </div>
  </section>

  <form method="GET" action="/packages" class="filter-form">
    <label>
      Search
      <input
        type="text"
        name="search"
        placeholder="Destination or package"
        value="<%= filters.search %>"
      />
    </label>
    <label>
      Max Price (INR)
      <input type="number" name="maxPrice" min="1000" value="<%= filters.maxPrice %>" />
    </label>
    <label>
      Sort By
      <select name="sort">
        <option value="popular" <%= filters.sort === 'popular' ? 'selected' : '' %>>Popular</option>
        <option value="price-asc" <%= filters.sort === 'price-asc' ? 'selected' : '' %>>Price Low to High</option>
        <option value="price-desc" <%= filters.sort === 'price-desc' ? 'selected' : '' %>>Price High to Low</option>
        <option value="duration" <%= filters.sort === 'duration' ? 'selected' : '' %>>Shortest Duration</option>
      </select>
    </label>
    <button class="btn btn-primary" type="submit">Apply</button>
  </form>

  <section class="package-grid">
    <% if (packages.length === 0) { %>
    <p class="empty-state">No packages match your filters. Try adjusting search or max price.</p>
    <% } %>

    <% packages.forEach((pkg) => { %>
    <article class="package-card">
      <img src="<%= pkg.image %>" alt="<%= pkg.name %>" />
      <div class="package-card-body">
        <p class="meta"><%= pkg.destination %> | ⭐ <%= pkg.rating.toFixed(1) %></p>
        <h3><%= pkg.name %></h3>
        <p class="description"><%= pkg.description %></p>
        <div class="tags">
          <% pkg.tags.slice(0, 3).forEach((tag) => { %>
          <span><%= tag %></span>
          <% }) %>
        </div>
        <div class="card-bottom">
          <p class="price"><%= formatINR(pkg.price) %></p>
          <a href="/packages/<%= pkg._id %>" class="btn-text">Details</a>
        </div>
      </div>
    </article>
    <% }) %>
  </section>
</main>

<%- include('partials/footer') %>
<%- include('partials/end') %>
